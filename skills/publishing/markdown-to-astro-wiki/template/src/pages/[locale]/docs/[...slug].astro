---
import { getCollection } from 'astro:content';
import DocLayout from '../../../layouts/DocLayout.astro';
import { localizedDocTitle, normalizeLocale, t } from '../../../i18n';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const locales = ['en', 'fr'];
  return locales.flatMap((locale) =>
    docs.map((doc) => ({
      params: { locale, slug: doc.slug },
      props: { doc, locale },
    })),
  );
}

const { doc, locale: routeLocale } = Astro.props;
const locale = normalizeLocale(routeLocale);
const frDocs = await getCollection('frDocs');
const frDocsBySlug = new Map(frDocs.map((entry) => [entry.slug, entry]));
const localizedDoc = locale === 'fr' ? frDocsBySlug.get(doc.slug) ?? doc : doc;
const { Content, headings } = await localizedDoc.render();
const copy = t(locale);
const title = localizedDocTitle(locale, doc.slug, localizedDoc.data.title || doc.data.title);
const description = localizedDoc.data.description || doc.data.description;
const categoryKey = (localizedDoc.data.category || doc.data.category || 'general') as keyof typeof copy.categories;
const category = copy.categories[categoryKey] || localizedDoc.data.category || doc.data.category;
---

<DocLayout
  title={title}
  description={description}
  category={category}
  headings={headings}
  locale={locale}
>
  <Content />
</DocLayout>
