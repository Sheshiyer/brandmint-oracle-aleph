---
import PortalHome from '../../components/PortalHome.astro';
import { LOCALES, normalizeLocale } from '../../i18n';

export async function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = normalizeLocale(Astro.params.locale);
---

<PortalHome locale={locale} />
