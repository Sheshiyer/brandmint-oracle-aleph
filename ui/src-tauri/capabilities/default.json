{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Brandmint desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:default",
    "notification:default",
    "notification:allow-notify",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "process:default",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
