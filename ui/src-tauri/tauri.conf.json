{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Brandmint",
  "version": "4.4.1",
  "identifier": "com.brandmint.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4188",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Brandmint v4.4.1",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "externalBin": [
      "binaries/brandmint-bridge"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGRDZDQ0JGNjQzQUUyQkUKUldTKzRqcGt2OHpXLzYzZHNQYks2OW9JT0JGQXVSY3JPYnAzVWUzbEhmTEFuak9MQjVDd3J2S1IK"
    }
  }
}
