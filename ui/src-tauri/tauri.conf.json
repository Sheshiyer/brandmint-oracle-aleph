{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Brandmint",
  "version": "5.0.0",
  "identifier": "com.brandmint.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4188",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Brandmint v5.0.0",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": null
    },
    "externalBin": [
      "binaries/brandmint-bridge"
    ]
  }
}
