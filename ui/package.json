{
  "name": "brandmint-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4188 --strictPort",
    "dev:guard": "python3 ../scripts/localhost_port_guard.py --port 4188 --retries 2 -- npm run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4188 --strictPort"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
